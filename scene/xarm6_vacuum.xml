                    <geom name="vacuum_cup_geom" type="cylinder" pos="0 0 0.078" size="0.035 0.008" material="vacuum_rubber"
                          mass="0.08" friction="1.2 1.2 1.2"/>
                    <site name="vacuum_suction_site" pos="0 0 0.087" type="sphere" size="0.008" rgba="0 0.8 1 0.85"/>
                    <site name="link_tcp" pos="0 0 0.087" type="sphere" size="0.01" rgba="1 0 0 0" group="1"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <velocity name="vel1" joint="joint1" kv="1000" ctrlrange="-3.14159 3.14159" forcerange="-50 50"/>
    <velocity name="vel2" joint="joint2" kv="1000" ctrlrange="-3.14159 3.14159" forcerange="-50 50"/>
    <velocity name="vel3" joint="joint3" kv="1000" ctrlrange="-3.14159 3.14159" forcerange="-30 30"/>
    <velocity name="vel4" joint="joint4" kv="1000" ctrlrange="-3.14159 3.14159" forcerange="-30 30"/>
    <velocity name="vel5" joint="joint5" kv="1000" ctrlrange="-3.14159 3.14159" forcerange="-20 20"/>
    <velocity name="vel6" joint="joint6" kv="1000" ctrlrange="-3.14159 3.14159" forcerange="-20 20"/>
  </actuator>
</mujoco>
