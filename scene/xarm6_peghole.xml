<mujoco model="xarm6">
  <compiler angle="radian" autolimits="true" meshdir="assets"/>

  <!-- <option integrator="implicitfast" gravity="0 0 -9.81"/> -->
  <!-- 力传感器重力补偿 -->
  <option integrator="implicitfast" gravity="0 0 0"/>

  <asset>
    <material name="white" rgba="1 1 1 1"/>
    <material name="gray" rgba="0.753 0.753 0.753 1"/>
    <material name="black" rgba="0.149 0.149 0.149 1"/>

    <mesh file="link_base.stl"/>
    <mesh file="link1.stl"/>
    <mesh file="link2.stl"/>
    <mesh file="link3.stl"/>
    <mesh file="link4.stl"/>
    <mesh file="link5.stl"/>
    <mesh file="link6.stl"/>
    <mesh file="end_tool.stl"/>
    <mesh file="base_link.stl"/>
    <mesh file="left_outer_knuckle.stl"/>
    <mesh file="left_finger.stl"/>
    <mesh file="left_inner_knuckle.stl"/>
    <mesh file="right_outer_knuckle.stl"/>
    <mesh file="right_finger.stl"/>
    <mesh file="right_inner_knuckle.stl"/>
    <mesh file="d435_with_cam_stand.stl"/>
  </asset>

  <default>
    <default class="xarm6">
      <geom type="mesh" material="white"/>
      <joint axis="0 0 1" armature="0.1" range="-6.28319 6.28319" frictionloss="1"/>
      <general biastype="affine" ctrlrange="-6.28319 6.28319"/>
      <default class="size1">
        <joint damping="0.1"/>
        <general gainprm="1500" biasprm="0 -1500 -150" forcerange="-50 50"/>
      </default>
      <default class="size2">
        <joint damping="0.1"/>
        <general gainprm="1000" biasprm="0 -1000 -100" forcerange="-30 30"/>
      </default>
      <default class="size3">
        <joint damping="0.1"/>
        <general gainprm="800" biasprm="0 -800 -80" forcerange="-20 20"/>
      </default>
      <default class="spring_link">
        <joint range="0 0.85" stiffness="0.05" springref="2.62" damping="0.00125"/>
      </default>
      <default class="driver">
        <joint range="0 0.85" armature="0.005" damping="0.1" solreflimit="0.005 1"/>
      </default>
      <default class="follower">
        <joint range="0 0.85" solreflimit="0.005 1"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3"/>
        <default class="pad_box1">
          <geom type="box" friction="0.7" solimp="0.95 0.99 0.001" solref="0.004 1" mass="0" priority="1" size="0.015 0.002 0.0095" rgba="0.0 0.1 0.7 1"/>
        </default>
        <default class="pad_box2">
          <geom type="box" friction="0.6" solimp="0.95 0.99 0.001" solref="0.004 1" mass="0" priority="1" size="0.015 0.002 0.0095" rgba="0.0 0.5 0.5 1"/>
        </default>
      </default>
      <site size="0.001" rgba="1 0 0 1" group="4"/>
    </default>
  </default>

  <worldbody>
    <body name="line_base" pos="0 0 0" childclass="xarm6">
      <inertial pos="-0.021131 -0.0016302 0.056488" quat="0.696843 0.20176 0.10388 0.680376" mass="0.88556"
        diaginertia="0.00382023 0.00335282 0.00167725"/>
      <geom mesh="link_base"/>

      <body name="link1" pos="0 0 0.267">
        <inertial pos="-0.0002 0.02905 -0.01233" quat="0.978953 -0.202769 -0.00441617 -0.0227264" mass="2.382"
          diaginertia="0.00569127 0.00533384 0.00293865"/>
        <joint name="joint1" class="size1"/>
        <geom mesh="link1"/>

        <body name="link2" quat="1 -1 0 0">
          <inertial pos="0.03881 -0.22783 0.03496" quat="0.635305 0.753023 0.170976 -0.010531" mass="2.2675"
            diaginertia="0.0294477 0.0281783 0.00383449"/>
          <joint name="joint2" range="-2.059 2.0944" class="size1"/>
          <geom mesh="link2"/>

          <body name="link3" pos="0.0535 -0.2845 0">
            <inertial pos="0.07041 0.11631 0.0107" quat="0.845838 0.425539 -0.293179 0.132369" mass="1.875"
              diaginertia="0.00714132 0.00699471 0.00196753"/>
            <joint name="joint3" range="-3.927 0.19198" class="size2"/>
            <geom mesh="link3"/>

            <body name="link4" pos="0.0775 0.3425 0" quat="1 -1 0 0">
              <inertial pos="-0.00018 0.01798 -0.02291" quat="0.99929 -0.0369702 0.00179434 -0.00701174" mass="1.3192"
                diaginertia="0.00489614 0.00447403 0.00132609"/>
              <joint name="joint4" class="size2"/>
              <geom mesh="link4"/>

              <body name="link5" pos="0 0 0" quat="1 1 0 0">
                <inertial pos="0.0651 0.03096 0.00315" quat="-0.223008 0.771309 0.16027 0.574163" mass="1.33854"
                  diaginertia="0.00241824 0.00213367 0.00108731"/>
                <joint name="joint5" range="-1.69297 3.14159" class="size3"/>
                <geom mesh="link5"/>

                <body name="link6" pos="0.076 0.097 0" quat="1 -1 0 0">
                  <inertial pos="0.00763576 -0.00272358 0.0307029" quat="0.634077 -0.153028 -0.073538 0.754401" mass="0.838615"
                    diaginertia="0.00129456 0.00116006 0.00078716"/>
                  <joint name="joint6" class="size3"/>
                  <geom material="gray" mesh="end_tool" quat="0 0 0 1"/>
                  <geom name="d435" material="gray" mesh="d435_with_cam_stand" class="visual"/>
                  <camera name="camera1" pos="0.1 -0.015 0.02" euler="3.1415 0.1745329 1.5707" fovy="42" resolution="1920 1080"/>

                  <body name="force_sensor" pos="0 0 0.022" quat="1 0 0 0">
                    <inertial pos="0 0 0" quat="1 0 0 0" mass="0.3" diaginertia="0.000143 0.000143 0.000211"/>
                    <geom type="cylinder" size="0.0375 0.01925" name="force_sensor_cyl" material="black" mass="0.3" condim="4" friction="1 1 1" solimp="1 1 1" solref="0.02 1"/>

                    <body name="cylinder_tcp" pos="0 0 0.07125" quat="1 0 0 0">
                      <inertial pos="0 0 0" quat="1 0 0 0"
                        mass="0.3" diaginertia="0.000261 0.000184 0.000141"/>
                      
                      <geom type="box" size="0.025 0.025 0.0525" name="tcp" material="black" 
                        mass="0.3" condim="4" friction="1 1 1" solimp="1 1 1" solref="0.02 1"/>
                      
                      <site name="force_torque" pos="0 0 -0.07125" quat="1 0 0 0" type="sphere" size="0.01" rgba="1 0 0 1" group="1"/>

                      <site name="link_tcp" pos="0 0 0.0525" type="sphere" size="0.01" rgba="1 0 0 0" group="1"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <sensor>
    <force name="force" site="force_torque"/>
    <torque name="torque" site="force_torque"/>

    <!-- <jointvel name="vel_joint1" joint="joint1"/>
    <jointvel name="vel_joint2" joint="joint2"/>
    <jointvel name="vel_joint3" joint="joint3"/>
    <jointvel name="vel_joint4" joint="joint4"/>
    <jointvel name="vel_joint5" joint="joint5"/>
    <jointvel name="vel_joint6" joint="joint6"/> -->

  </sensor>

  <actuator>
    <velocity name="vel1" joint="joint1" kv="500" ctrlrange="-3.14159 3.14159" forcerange="-50 50"/>
    <velocity name="vel2" joint="joint2" kv="500" ctrlrange="-3.14159 3.14159" forcerange="-50 50"/>
    <velocity name="vel3" joint="joint3" kv="500" ctrlrange="-3.14159 3.14159" forcerange="-30 30"/>
    <velocity name="vel4" joint="joint4" kv="500" ctrlrange="-3.14159 3.14159" forcerange="-30 30"/>
    <velocity name="vel5" joint="joint5" kv="500" ctrlrange="-3.14159 3.14159" forcerange="-20 20"/>
    <velocity name="vel6" joint="joint6" kv="500" ctrlrange="-3.14159 3.14159" forcerange="-20 20"/>
    
    <!-- <general name="gripper" tendon="split" forcerange="-50 50" ctrlrange="0 255" biastype="affine" gainprm="0.333"
      biasprm="0 -100 -10"/> -->
  </actuator>
  <!-- <keyframe>
    <key name="home" qpos="0.0157 -0.88314 -0.80634 0 1.68948 0.020943 0.5 0 0.55 1 0 0 0 0.5 0 0.3 1 0 0 0" ctrl="0 0 0 0 0 0 "/>
  </keyframe> -->
</mujoco>